# AgroBot — Environment Variables
# =====================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────
# Get your free key at: https://console.groq.com/
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# ── Optional: Disease Detection ───────────────────────────────
# Kindwise Crop Health API (https://crop.kindwise.com/)
# If not set, AgroBot uses Groq Vision (llama-4-scout) — no extra key needed.
KINDWISE_API_KEY=YOUR_KINDWISE_API_KEY_HERE

# ── Optional: Weather (not required — Open-Meteo is free) ─────
# OpenWeatherMap key (https://openweathermap.org/api)
# If not set, AgroBot uses Open-Meteo (100% free, no key).
OPENWEATHERMAP_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE
